<script>
/* CURSOR */
var cur=document.getElementById('cur'),ring=document.getElementById('ring'),mx=0,my=0,rx=0,ry=0;
document.addEventListener('mousemove',function(e){mx=e.clientX;my=e.clientY;cur.style.transform='translate('+mx+'px,'+my+'px) translate(-50%,-50%)';});
(function aR(){rx+=(mx-rx)*.1;ry+=(my-ry)*.1;ring.style.transform='translate('+rx+'px,'+ry+'px) translate(-50%,-50%)';requestAnimationFrame(aR);})();
document.querySelectorAll('a,button,.proj-card,.stack-cat,.highlight,.stat-item,.brand-item').forEach(function(el){
  el.addEventListener('mouseenter',function(){document.body.classList.add('ch');});
  el.addEventListener('mouseleave',function(){document.body.classList.remove('ch');});
});

/* SCROLL PROGRESS */
var sp=document.getElementById('sprog');
window.addEventListener('scroll',function(){if(sp)sp.style.width=((window.scrollY/(document.body.scrollHeight-window.innerHeight))*100)+'%';});

/* NAV SCROLL */
window.addEventListener('scroll',function(){document.getElementById('nav').style.padding=window.scrollY>60?'12px 5vw':'20px 5vw';});

/* REVEAL */
var obs=new IntersectionObserver(function(es){es.forEach(function(e){if(e.isIntersecting)setTimeout(function(){e.target.classList.add('visible');},+(e.target.dataset.d||0));});},{threshold:.1});
document.querySelectorAll('.reveal').forEach(function(el,i){el.dataset.d=(i%5)*80;obs.observe(el);});

/* COUNT UP */
function countUp(el,t,s){var v=0,inc=t/100;var tm=setInterval(function(){v=Math.min(v+inc,t);el.textContent=Math.floor(v)+s;if(v>=t)clearInterval(tm);},16);}
var sO=new IntersectionObserver(function(es){es.forEach(function(e){if(e.isIntersecting&&!e.target.dataset.done){e.target.dataset.done=1;var r=e.target.textContent,n=parseInt(r.replace(/[^0-9]/g,'')),s=r.replace(/[0-9]/g,'');countUp(e.target,n,s);}});},{threshold:.5});
document.querySelectorAll('.stat-num').forEach(function(el){sO.observe(el);});
</script>

<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Enald A. | Founder & Lead Developer — DevEdge Digital</title>
<meta name="description" content="Enald A. — Founder & Lead Developer at DevEdge Digital. 11+ years building high-performance brands, websites, and digital experiences.">
<link rel="preconnect" href="https://fonts.googleapis.com">
<link href="https://fonts.googleapis.com/css2?family=JetBrains+Mono:ital,wght@0,300;0,400;0,600;0,700;0,800;1,400&family=Space+Grotesk:wght@300;400;500;600;700&display=swap" rel="stylesheet">
<style>
*,*::before,*::after{margin:0;padding:0;box-sizing:border-box;}
:root{
  --dark:#020408;
  --dark2:#060d14;
  --dark3:#0a1520;
  --dark4:#0f1e2e;
  --neon:#00f5a0;
  --neon2:#00d4ff;
  --neon3:#7b2fff;
  --orange:#ff6b2b;
  --text:#e8f4f8;
  --muted:#4a6a7a;
  --border:rgba(0,245,160,.08);
  --border2:rgba(0,212,255,.08);
  --grad:linear-gradient(135deg,#00f5a0 0%,#00d4ff 100%);
  --grad2:linear-gradient(135deg,#7b2fff 0%,#00d4ff 100%);
  --grad3:linear-gradient(135deg,#ff6b2b 0%,#00f5a0 100%);
  --glow:0 0 30px rgba(0,245,160,.15);
  --glow2:0 0 30px rgba(0,212,255,.15);
}
html{scroll-behavior:smooth;}
body{font-family:'Space Grotesk',sans-serif;background:var(--dark);color:var(--text);overflow-x:hidden;cursor:none;-webkit-font-smoothing:antialiased;}

/* NOISE OVERLAY */
body::before{content:'';position:fixed;inset:0;background-image:url("data:image/svg+xml,%3Csvg viewBox='0 0 256 256' xmlns='http://www.w3.org/2000/svg'%3E%3Cfilter id='noise'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='0.9' numOctaves='4' stitchTiles='stitch'/%3E%3C/filter%3E%3Crect width='100%25' height='100%25' filter='url(%23noise)' opacity='0.03'/%3E%3C/svg%3E");pointer-events:none;z-index:9999;opacity:.4;}

/* SCANLINES */
body::after{content:'';position:fixed;inset:0;background:repeating-linear-gradient(0deg,transparent,transparent 2px,rgba(0,0,0,.03) 2px,rgba(0,0,0,.03) 4px);pointer-events:none;z-index:9998;}

/* CURSOR */
.cur{width:4px;height:4px;border-radius:50%;background:var(--neon);position:fixed;top:0;left:0;pointer-events:none;z-index:99998;transform:translate(-50%,-50%);box-shadow:0 0 12px rgba(0,245,160,1),0 0 24px rgba(0,245,160,.6);}
.cur-ring{width:24px;height:24px;border:1px solid rgba(0,245,160,.4);border-radius:50%;position:fixed;top:0;left:0;pointer-events:none;z-index:99997;transform:translate(-50%,-50%);transition:width .15s,height .15s;}
body.ch .cur{background:var(--neon2);box-shadow:0 0 12px rgba(0,212,255,1);}
body.ch .cur-ring{border-color:rgba(0,212,255,.4);width:36px;height:36px;}
@media(hover:none){.cur,.cur-ring{display:none;}body{cursor:auto;}}

/* SCROLL PROGRESS */
#sprog{position:fixed;top:0;left:0;height:1px;z-index:9999;background:var(--grad);width:0%;box-shadow:0 0 10px rgba(0,245,160,.8);}

/* NAV */
nav{position:fixed;top:0;left:0;right:0;z-index:200;display:flex;align-items:center;justify-content:space-between;padding:20px 5vw;background:rgba(2,4,8,.92);backdrop-filter:blur(24px);border-bottom:1px solid var(--border);transition:padding .3s;}
.nav-logo{font-family:'JetBrains Mono',monospace;font-weight:700;font-size:.95rem;text-decoration:none;color:var(--text);display:flex;align-items:center;gap:10px;}
.nav-logo-dot{width:8px;height:8px;border-radius:50%;background:var(--neon);box-shadow:0 0 10px rgba(0,245,160,.8);animation:logoPulse 2s infinite;}
@keyframes logoPulse{0%,100%{box-shadow:0 0 10px rgba(0,245,160,.8)}50%{box-shadow:0 0 20px rgba(0,245,160,1),0 0 40px rgba(0,245,160,.4)}}
.nav-logo span{background:var(--grad);-webkit-background-clip:text;-webkit-text-fill-color:transparent;background-clip:text;}
.nav-links{display:flex;gap:28px;list-style:none;}
.nav-links a{text-decoration:none;color:var(--muted);font-size:.7rem;letter-spacing:.14em;text-transform:uppercase;font-family:'JetBrains Mono',monospace;transition:color .2s;position:relative;}
.nav-links a:hover{color:var(--neon);}
.nav-links a::after{content:'';position:absolute;bottom:-3px;left:0;width:0;height:1px;background:var(--neon);transition:width .3s;box-shadow:0 0 6px rgba(0,245,160,.8);}
.nav-links a:hover::after{width:100%;}
.nav-back{font-family:'JetBrains Mono',monospace;font-size:.68rem;color:var(--muted);text-decoration:none;letter-spacing:.1em;padding:7px 16px;border:1px solid var(--border);border-radius:3px;transition:all .2s;}
.nav-back:hover{color:var(--neon);border-color:rgba(0,245,160,.3);box-shadow:var(--glow);}

/* HERO */
.hero{min-height:100vh;display:flex;align-items:center;position:relative;overflow:hidden;padding:120px 5vw 80px;}
.hero-grid-bg{position:absolute;inset:0;background-image:linear-gradient(rgba(0,245,160,.03) 1px,transparent 1px),linear-gradient(90deg,rgba(0,245,160,.03) 1px,transparent 1px);background-size:48px 48px;pointer-events:none;}
.hero-grid-bg::after{content:'';position:absolute;inset:0;background:radial-gradient(ellipse 80% 80% at 50% 50%,transparent 40%,var(--dark) 100%);}
.orb{position:absolute;border-radius:50%;filter:blur(100px);pointer-events:none;animation:orbF 12s ease-in-out infinite;}
.orb1{width:600px;height:600px;background:rgba(0,245,160,.05);top:-150px;right:-100px;}
.orb2{width:500px;height:500px;background:rgba(0,212,255,.04);bottom:-120px;left:-100px;animation-delay:-5s;}
.orb3{width:350px;height:350px;background:rgba(123,47,255,.04);top:40%;right:20%;animation-delay:-8s;}
@keyframes orbF{0%,100%{transform:translate(0,0)scale(1);}33%{transform:translate(30px,-20px)scale(1.04);}66%{transform:translate(-20px,30px)scale(.96);}}
.hero-content{position:relative;z-index:2;max-width:1200px;margin:0 auto;width:100%;display:grid;grid-template-columns:1fr 380px;gap:80px;align-items:center;}
.hero-left{opacity:0;animation:fadeU .8s .1s ease forwards;}

/* HERO TITLE */
.hero-eyebrow{font-family:'JetBrains Mono',monospace;font-size:.68rem;color:var(--neon);letter-spacing:.2em;text-transform:uppercase;margin-bottom:20px;display:flex;align-items:center;gap:12px;}
.hero-eyebrow::before{content:'';width:32px;height:1px;background:var(--neon);box-shadow:0 0 8px rgba(0,245,160,.8);}
.hero-title{
  font-family:'Space Grotesk',sans-serif;
  font-size:clamp(3rem,5.5vw,5.5rem);
  font-weight:700;
  line-height:1.02;
  letter-spacing:-.02em;
  margin-bottom:8px;
}
.hero-title .line1{display:block;color:var(--text);}
.hero-title .line2{display:block;background:var(--grad);-webkit-background-clip:text;-webkit-text-fill-color:transparent;background-clip:text;position:relative;}
.hero-title .line3{
  display:block;
  color:rgba(232,244,248,.42);
  font-weight:400;
  font-size:clamp(1.8rem,3vw,3rem);
  margin-top:8px;
  font-style:normal;
  letter-spacing:-.01em;
}
.hero-role{font-family:'JetBrains Mono',monospace;font-size:.82rem;color:var(--muted);margin:20px 0 26px;display:flex;align-items:center;gap:8px;flex-wrap:wrap;}
.role-tag{padding:4px 10px;border:1px solid rgba(0,245,160,.2);border-radius:2px;color:var(--neon);font-size:.68rem;letter-spacing:.1em;}
.hero-desc{font-size:1.08rem;line-height:1.85;color:rgba(232,244,248,.65);max-width:500px;margin-bottom:36px;font-weight:300;}
.hero-btns{display:flex;gap:12px;flex-wrap:wrap;}
.btn-neon{padding:12px 28px;background:transparent;border:1px solid var(--neon);color:var(--neon);text-decoration:none;font-size:.8rem;font-family:'JetBrains Mono',monospace;letter-spacing:.08em;border-radius:3px;transition:all .3s;position:relative;overflow:hidden;}
.btn-neon::before{content:'';position:absolute;inset:0;background:var(--neon);transform:translateX(-101%);transition:transform .3s;z-index:-1;}
.btn-neon:hover{color:#020408;box-shadow:0 0 30px rgba(0,245,160,.4);}
.btn-neon:hover::before{transform:translateX(0);}
.btn-ghost{padding:12px 28px;border:1px solid var(--border2);color:var(--neon2);text-decoration:none;font-size:.8rem;font-family:'JetBrains Mono',monospace;letter-spacing:.08em;border-radius:3px;transition:all .3s;}
.btn-ghost:hover{border-color:var(--neon2);background:rgba(0,212,255,.06);box-shadow:var(--glow2);}

/* HERO TERMINAL */
.hero-terminal{opacity:0;animation:slideL .8s .5s ease forwards;font-family:'JetBrains Mono',monospace;}
.terminal-window{background:rgba(6,13,20,.96);border:1px solid rgba(0,245,160,.15);border-radius:10px;overflow:hidden;box-shadow:0 0 0 1px rgba(255,255,255,.03),0 40px 80px rgba(0,0,0,.7),var(--glow);}
.terminal-bar{background:var(--dark3);padding:11px 16px;display:flex;align-items:center;gap:8px;border-bottom:1px solid rgba(0,245,160,.08);}
.t-dot{width:10px;height:10px;border-radius:50%;}
.t-dot.r{background:#ff5f57;}.t-dot.y{background:#ffbd2e;}.t-dot.g{background:#28c840;}
.t-title{font-size:.62rem;color:var(--muted);margin-left:8px;letter-spacing:.1em;}
.terminal-body{padding:20px 18px;font-size:.78rem;line-height:2;}
.tl{display:flex;gap:6px;align-items:baseline;flex-wrap:wrap;}
.tp{color:var(--neon);}.tc{color:var(--text);}.tk{color:var(--neon2);}.tv{color:#c792ea;}
.ts{color:#c3e88d;}.tn{color:#f78c6c;}.tm{color:var(--muted);font-style:italic;}
.to{padding-left:18px;color:var(--muted);}
.tcur{display:inline-block;width:6px;height:13px;background:var(--neon);margin-left:2px;vertical-align:middle;animation:blk .9s step-end infinite;box-shadow:0 0 8px rgba(0,245,160,.8);}
@keyframes blk{0%,100%{opacity:1}50%{opacity:0}}

/* STATS BAR */
.stats-bar{border-top:1px solid var(--border);border-bottom:1px solid var(--border);background:var(--dark2);padding:40px 5vw;}
.stats-inner{max-width:1100px;margin:0 auto;display:grid;grid-template-columns:repeat(5,1fr);gap:20px;text-align:center;}
.stat-item{cursor:default;transition:transform .3s;}
.stat-item:hover{transform:translateY(-4px);}
.stat-num{
  font-family:'Space Grotesk',sans-serif;
  font-size:2.2rem;
  font-weight:700;
  letter-spacing:-.02em;
  background:var(--grad);
  -webkit-background-clip:text;
  -webkit-text-fill-color:transparent;
  background-clip:text;
  display:inline-block;
}
.stat-label{font-family:'JetBrains Mono',monospace;font-size:.6rem;color:var(--muted);letter-spacing:.15em;text-transform:uppercase;margin-top:6px;}

/* SHARED */
.section{padding:100px 5vw;max-width:1200px;margin:0 auto;}
.section-bg{background:var(--dark2);border-top:1px solid var(--border);}
.label-tag{display:inline-flex;align-items:center;gap:10px;font-size:.62rem;letter-spacing:.2em;text-transform:uppercase;color:var(--neon);font-family:'JetBrains Mono',monospace;margin-bottom:18px;}
.label-tag::before{content:'//';opacity:.4;font-size:.6rem;}
.section-title{
  font-family:'Space Grotesk',sans-serif;
  font-size:clamp(2rem,3.5vw,3.2rem);
  font-weight:700;
  line-height:1.1;
  letter-spacing:-.02em;
  margin-bottom:20px;
}
.section-title .hl{background:var(--grad);-webkit-background-clip:text;-webkit-text-fill-color:transparent;background-clip:text;}
.section-title .hl2{background:var(--grad2);-webkit-background-clip:text;-webkit-text-fill-color:transparent;background-clip:text;}

/* ABOUT */
.about-grid{display:grid;grid-template-columns:380px 1fr;gap:80px;align-items:start;}
.about-photo-wrap{position:relative;}
.about-photo-frame{border-radius:12px;overflow:hidden;border:1px solid rgba(0,245,160,.12);box-shadow:0 0 60px rgba(0,245,160,.08),0 40px 80px rgba(0,0,0,.6);}
.about-photo-frame img{width:100%;display:block;filter:saturate(1.1) contrast(1.05);}
.about-photo-overlay{position:absolute;inset:0;background:linear-gradient(to top,rgba(2,4,8,.8) 0%,transparent 50%);}
.about-corner{position:absolute;width:40px;height:40px;border-color:var(--neon);border-style:solid;opacity:.4;}
.about-corner.tl{top:-1px;left:-1px;border-width:2px 0 0 2px;border-radius:3px 0 0 0;}
.about-corner.tr{top:-1px;right:-1px;border-width:2px 2px 0 0;border-radius:0 3px 0 0;}
.about-corner.bl{bottom:-1px;left:-1px;border-width:0 0 2px 2px;border-radius:0 0 0 3px;}
.about-corner.br{bottom:-1px;right:-1px;border-width:0 2px 2px 0;border-radius:0 0 3px 0;}
.about-status{position:absolute;bottom:16px;left:16px;right:16px;background:rgba(6,13,20,.95);border:1px solid rgba(0,245,160,.2);border-radius:6px;padding:12px 14px;backdrop-filter:blur(10px);display:flex;align-items:center;gap:10px;}
.status-dot{width:7px;height:7px;border-radius:50%;background:var(--neon);flex-shrink:0;animation:logoPulse 2s infinite;}
.status-text{font-family:'JetBrains Mono',monospace;font-size:.65rem;color:var(--neon);letter-spacing:.1em;}
.about-body{font-size:1.05rem;line-height:1.9;color:rgba(232,244,248,.72);font-weight:300;}
.about-body p+p{margin-top:16px;}
.about-body strong{color:var(--text);font-weight:500;}
.about-highlights{display:grid;grid-template-columns:1fr 1fr;gap:10px;margin-top:28px;}
.highlight{padding:14px 16px;background:var(--dark3);border:1px solid var(--border);border-radius:6px;border-left:2px solid var(--neon);transition:all .3s;cursor:default;}
.highlight:hover{background:rgba(0,245,160,.03);border-left-color:var(--neon2);box-shadow:var(--glow);}
.highlight h5{font-family:'JetBrains Mono',monospace;font-size:.7rem;color:var(--neon);letter-spacing:.1em;text-transform:uppercase;margin-bottom:4px;}
.highlight p{font-size:.88rem;color:rgba(232,244,248,.6);line-height:1.5;}

/* SKILLS / STACK */
.stack-grid{display:grid;grid-template-columns:repeat(3,1fr);gap:16px;margin-top:48px;}
.stack-cat{padding:24px;background:var(--dark3);border:1px solid var(--border);border-radius:8px;transition:all .3s;cursor:default;}
.stack-cat:hover{border-color:rgba(0,245,160,.2);box-shadow:var(--glow);}
.stack-cat-label{font-family:'JetBrains Mono',monospace;font-size:.6rem;color:var(--neon);letter-spacing:.18em;text-transform:uppercase;margin-bottom:14px;display:flex;align-items:center;gap:8px;}
.stack-cat-label::before{content:'';width:16px;height:1px;background:var(--neon);box-shadow:0 0 6px rgba(0,245,160,.6);}
.stack-tags{display:flex;flex-wrap:wrap;gap:6px;}
.stack-tag{font-family:'JetBrains Mono',monospace;font-size:.65rem;padding:4px 10px;background:rgba(0,245,160,.05);border:1px solid rgba(0,245,160,.12);color:rgba(232,244,248,.7);border-radius:3px;letter-spacing:.06em;transition:all .2s;}
.stack-tag:hover{border-color:rgba(0,245,160,.3);color:var(--neon);background:rgba(0,245,160,.08);}

/* PROJECTS */
.projects-grid{display:grid;grid-template-columns:repeat(3,1fr);gap:14px;margin-top:48px;}
.proj-card{border-radius:8px;overflow:hidden;border:1px solid var(--border);position:relative;cursor:pointer;transition:transform .35s,border-color .3s,box-shadow .3s;background:var(--dark3);}
.proj-card:hover{transform:translateY(-8px);border-color:rgba(0,245,160,.25);box-shadow:0 24px 60px rgba(0,0,0,.6),var(--glow);}
.proj-browser-bar{background:var(--dark4);padding:9px 14px;display:flex;align-items:center;gap:6px;border-bottom:1px solid var(--border);}
.proj-dot{width:8px;height:8px;border-radius:50%;}
.proj-dot.r{background:#ff5f57;}.proj-dot.y{background:#ffbd2e;}.proj-dot.g{background:#28c840;}
.proj-url{font-family:'JetBrains Mono',monospace;font-size:.56rem;color:var(--muted);margin-left:8px;}
.proj-img{width:100%;aspect-ratio:16/10;object-fit:cover;object-position:top;display:block;transition:transform .4s,filter .4s;}
.proj-card:hover .proj-img{transform:scale(1.04);filter:saturate(1.2);}
.proj-overlay{position:absolute;inset:0;background:linear-gradient(to top,rgba(2,4,8,.97) 0%,rgba(2,4,8,.3) 55%,transparent 100%);opacity:0;transition:opacity .3s;display:flex;align-items:flex-end;padding:18px;}
.proj-card:hover .proj-overlay{opacity:1;}
.proj-info{transform:translateY(8px);transition:transform .3s;}
.proj-card:hover .proj-info{transform:translateY(0);}
.proj-title{
  font-family:'Space Grotesk',sans-serif;
  font-size:.95rem;
  font-weight:700;
  letter-spacing:-.01em;
  margin-bottom:6px;
}
.proj-tags{display:flex;gap:5px;flex-wrap:wrap;}
.proj-tag{font-family:'JetBrains Mono',monospace;font-size:.56rem;padding:2px 7px;border:1px solid rgba(0,245,160,.25);color:var(--neon);border-radius:2px;letter-spacing:.08em;}
.proj-actions{display:flex;gap:8px;margin-top:8px;align-items:center;}
.proj-visit{font-family:'JetBrains Mono',monospace;font-size:.65rem;color:var(--neon);text-decoration:none;letter-spacing:.08em;transition:opacity .2s;}
.proj-visit:hover{opacity:.7;}

/* BRANDS */
.brands-marquee-wrap{overflow:hidden;border-top:1px solid var(--border);border-bottom:1px solid var(--border);background:var(--dark2);padding:28px 0;}
.brands-marquee{display:flex;gap:0;animation:marquee 30s linear infinite;white-space:nowrap;}
.brand-item{display:inline-flex;align-items:center;justify-content:center;padding:0 28px;height:50px;}
.brand-item img{height:32px;width:auto;object-fit:contain;filter:grayscale(100%) brightness(0.6);transition:filter .3s;opacity:.6;}
.brand-item img:hover{filter:grayscale(0%) brightness(1);opacity:1;}
@keyframes marquee{0%{transform:translateX(0)}100%{transform:translateX(-50%)}}

/* TESTIMONIAL */
.testi-wrap{max-width:720px;margin:0 auto;text-align:center;}
.testi-quote{font-family:'JetBrains Mono',monospace;font-size:5rem;color:var(--neon);opacity:.12;line-height:1;margin-bottom:8px;}
.testi-text{
  font-family:'Space Grotesk',sans-serif;
  font-size:clamp(1.1rem,2vw,1.4rem);
  line-height:1.75;
  color:rgba(232,244,248,.8);
  font-style:normal;
  margin-bottom:22px;
  font-weight:500;
  letter-spacing:-.01em;
}
.testi-author{font-family:'JetBrains Mono',monospace;font-size:.68rem;letter-spacing:.16em;text-transform:uppercase;color:var(--muted);}
.testi-author strong{color:var(--neon);}

/* CTA */
.cta-section{padding:120px 5vw;text-align:center;position:relative;overflow:hidden;}
.cta-section::before{content:'';position:absolute;inset:0;background:radial-gradient(ellipse 70% 70% at 50% 50%,rgba(0,245,160,.05) 0%,transparent 100%);}
.cta-grid-bg{position:absolute;inset:0;background-image:linear-gradient(rgba(0,245,160,.02) 1px,transparent 1px),linear-gradient(90deg,rgba(0,245,160,.02) 1px,transparent 1px);background-size:48px 48px;animation:gridMove 20s linear infinite;}
@keyframes gridMove{0%{background-position:0 0}100%{background-position:48px 48px}}
.cta-inner{position:relative;z-index:1;max-width:680px;margin:0 auto;}
.cta-title{
  font-family:'Space Grotesk',sans-serif;
  font-size:clamp(2rem,3.5vw,3.2rem);
  font-weight:700;
  letter-spacing:-.02em;
  line-height:1.05;
  margin-bottom:18px;
}
.cta-title .hl{background:var(--grad);-webkit-background-clip:text;-webkit-text-fill-color:transparent;background-clip:text;}
.cta-sub{font-size:1rem;color:rgba(232,244,248,.6);line-height:1.8;margin-bottom:40px;font-weight:300;}
.cta-btns{display:flex;gap:12px;justify-content:center;flex-wrap:wrap;}

/* FOOTER */
footer{background:var(--dark2);padding:36px 5vw 24px;border-top:1px solid var(--border);}
.footer-inner{max-width:1100px;margin:0 auto;display:flex;justify-content:space-between;align-items:center;flex-wrap:wrap;gap:16px;}
.footer-name{font-family:'JetBrains Mono',monospace;font-size:.82rem;font-weight:700;color:var(--text);}
.footer-name span{background:var(--grad);-webkit-background-clip:text;-webkit-text-fill-color:transparent;background-clip:text;}
.footer-note{font-family:'JetBrains Mono',monospace;font-size:.6rem;color:var(--muted);letter-spacing:.08em;}
.footer-note a{color:var(--neon);text-decoration:none;}
.footer-soc{display:flex;gap:16px;}
.footer-soc a{font-family:'JetBrains Mono',monospace;font-size:.6rem;color:var(--muted);text-decoration:none;letter-spacing:.12em;text-transform:uppercase;transition:color .2s;}
.footer-soc a:hover{color:var(--neon);}

/* REVEAL */
.reveal{opacity:0;transform:translateY(22px);transition:opacity .6s ease,transform .6s ease;}
.reveal.visible{opacity:1;transform:none;}

/* ANIMATIONS */
@keyframes fadeU{from{opacity:0;transform:translateY(22px)}to{opacity:1;transform:none}}
@keyframes slideL{from{opacity:0;transform:translateX(30px)}to{opacity:1;transform:none}}

/* MOBILE */
@media(max-width:960px){
  .hero-content{grid-template-columns:1fr;}
  .hero-terminal{display:none;}
  .about-grid{grid-template-columns:1fr;gap:40px;}
  .stack-grid{grid-template-columns:1fr 1fr;}
  .projects-grid{grid-template-columns:1fr 1fr;}
  .stats-inner{grid-template-columns:repeat(3,1fr);}
  .nav-links{display:none;}
}
@media(max-width:600px){
